{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/*.js": { "runtime": "@vercel/node" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "crons": [
    {
      "path": "/api/update",
      "schedule": "0 * * * *"
    }
  ]
}
